```c
#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/bpf.h>
#include <linux/elf.h>
#include <linux/fs.h>
#include <linux/mm.h>

static int __init nethook_bpf_init(void)
{
    int err;

    pr_info("nethook_ko: Initializing eBPF program...\n");

    err = bpf_prog_load("nethook_bpf", BPF_PROG_TYPE_SCHED_CLS, 0, NULL, 0, 0);
    if (err) {
        pr_err("nethook_ko: Failed to initialize eBPF program: %d\n", err);
        return err;
    }

    pr_info("nethook_ko: eBPF program initialized.\n");
    return 0;
}

static void __exit nethook_bpf_exit(void)
{
    int err;

    pr_info("nethook_ko: Uninitializing eBPF program...\n");

    err = bpf_prog_unload("nethook_bpf");
    if (err) {
        pr_err("nethook_ko: Failed to unload eBPF program: %d\n", err);
    }

    pr_info("nethook_ko: eBPF program unloaded.\n");
}

module_init(nethook_bpf_init);
module_exit(nethook_bpf_exit);
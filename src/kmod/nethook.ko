```c
#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/bpf.h>
#include <linux/elf.h>
#include <linux/fs.h>
#include <linux/mm.h>

static int __init nethook_load_bpf(void)
{
    int err;
    void *bpf_obj;

    pr_info("nethook_ko: Loading eBPF object...\n");

    err = bpf_load_object(&bpf_obj, "/sys/fs/bpf/nethook_bpf");
    if (err) {
        pr_err("nethook_ko: Failed to load eBPF object: %d\n", err);
        return err;
    }

    pr_info("nethook_ko: eBPF object loaded.\n");
    return 0;
}

static void __exit nethook_unload_bpf(void)
{
    int err;

    pr_info("nethook_ko: Unloading eBPF object...\n");

    err = bpf_unload_object(&nethook_bpf);
    if (err) {
        pr_err("nethook_ko: Failed to unload eBPF object: %d\n", err);
    }

    pr_info("nethook_ko: eBPF object unloaded.\n");
}

module_init(nethook_load_bpf);
module_exit(nethook_unload_bpf);
